<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#212529">

        <TextView
            android:id="@+id/textViewBlockHeight"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#51CF66"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textViewBlockHashShort"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF" />

        <TextView
            android:id="@+id/textViewBlockTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#ADB5BD" />

        <TextView
            android:id="@+id/textViewTxCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#E9ECEF" />

    </LinearLayout>
</androidx.cardview.widget.CardView>