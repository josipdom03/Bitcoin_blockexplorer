<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:gravity="center_horizontal"
    android:background="#F8F9FA">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bitcoin History"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp"
        android:textColor="#212529"/>

    <EditText
        android:id="@+id/editTextSearch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Unesite broj (visinu) bloka"
        android:inputType="number"
        android:padding="12dp"
        android:textColor="#212529"
        android:background="@android:drawable/editbox_background"/>

    <Button
        android:id="@+id/btnSearchBlock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Traži po broju bloka" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#DEE2E6"
        android:layout_marginVertical="24dp"/>

    <Button
        android:id="@+id/btnShowRecent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Prikaži zadnjih 30 blokova"
        android:backgroundTint="#212529"
        android:textColor="#FFFFFF" />

</LinearLayout>